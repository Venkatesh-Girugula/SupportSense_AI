# SupportSense AI - Configuration Settings

# Google Gemini API Key (Required for LLM execution)
GEMINI_API_KEY=your_gemini_api_key_here

# LLM and Embeddings Model Settings
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage and Directories
# Absolute or relative to the backend/ execution path
DOCS_DIR=docs
DB_PATH=faiss_index

# Engine Thresholds
CONFIDENCE_THRESHOLD=0.40

# Logging
LOG_LEVEL=INFO
